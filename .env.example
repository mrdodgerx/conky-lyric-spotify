# Spotify Cookie (required for local lyricstify API usage)
# Get this from your browser:
#   1. Go to https://open.spotify.com (logged in)
#   2. F12 -> Network -> Refresh -> Click first request
#   3. Copy the full 'cookie:' header value
SPOTIFY_COOKIE=

# Lyricstify API (optional - local server)
LYRICSTIFY_PORT=3000
